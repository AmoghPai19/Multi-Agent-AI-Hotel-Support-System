# Copy to .env and fill in. .env is git-ignored.
# ── Local database (docker-compose) ─────────────────────────────
DB_PASSWORD=postgres
DATABASE_URL=postgresql://app_writer:app_writer_dev_pw@localhost:5432/hotel
DATABASE_URL_RO=postgresql://app_readonly:app_readonly_dev_pw@localhost:5432/hotel

# ── Supabase (filled in Step 4, when we wire Auth) ──────────────
SUPABASE_URL=
SUPABASE_JWKS_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM + tracing (Mithun's agents, later) ──────────────────────
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet
EMBEDDING_MODEL=text-embedding-3-small
LANGSMITH_API_KEY=
